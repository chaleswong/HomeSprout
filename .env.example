# HomeSprout 环境变量配置示例

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
SERVER_HOSTNAME=homesprout.local

# 认证配置
ADMIN_TOKEN=homesprout-admin-2026

# AI 配置（Ollama）
AI_ENABLED=true
AI_OLLAMA_URL=http://127.0.0.1:11434
AI_MODEL=qwen3-4b-optimized:latest

# Whisper 配置（可选）
WHISPER_ENABLED=false
WHISPER_BINARY_PATH=/path/to/whisper.cpp/main
WHISPER_MODEL_PATH=/path/to/models/ggml-medium.bin
